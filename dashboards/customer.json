          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT coalesce(sum(r.total_amount), 0)\n                       / greatest(count(DISTINCT s.subscriber_key), 1)\n                FROM dim_subscriber s\n                LEFT JOIN agg_revenue_minute r ON r.minute > now() - interval '24 hours'",
          "refId": "A"
        }
      ],
      "title": "ARPU (last 24h)",
      "type": "stat"
