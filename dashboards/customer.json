      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "telestream-pg"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT s.msisdn AS \"MSISDN\", s.province AS \"Province\",\n                       round(sum(f.mb_used), 1) AS \"MB Used\"\n                FROM fact_data_usage f\n                JOIN dim_subscriber s ON s.subscriber_key = f.subscriber_key\n                WHERE f.event_timestamp > now() - interval '1 hour'\n                GROUP BY 1, 2 ORDER BY 3 DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top Data Users (last hour)",
      "type": "table"
