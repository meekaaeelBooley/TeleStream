      },
      "id": 2,
      "options": {},
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "telestream-pg"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT m.minute AS time, t.tower_name AS metric, sum(m.session_count) AS value\n                FROM agg_data_minute m JOIN dim_tower t USING (tower_key)\n                WHERE $__timeFilter(m.minute)\n                GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Tower Load \u2014 Data Sessions per Minute",
      "type": "timeseries"
    },
