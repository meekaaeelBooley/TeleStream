        {
          "datasource": {
            "type": "postgres",
            "uid": "telestream-pg"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT t.tower_name AS \"Tower\", c.technology AS \"Tech\",\n                       c.signal_strength AS \"Signal\", c.connected_devices AS \"Devices\",\n                       c.status AS \"Status\", c.updated_at AS \"Updated\"\n                FROM tower_status_current c\n                JOIN dim_tower t USING (tower_id)\n                ORDER BY c.signal_strength ASC",
          "refId": "A"
        }
      ],
      "title": "Tower Status",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "telestream-pg"
