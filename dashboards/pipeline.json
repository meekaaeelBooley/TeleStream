      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "telestream-pg"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT rejected_at AS \"Rejected\", source_topic AS \"Topic\",\n                       rejection_reason AS \"Reason\",\n                       left(original_payload::text, 120) AS \"Payload\"\n                FROM dlq_records ORDER BY rejected_at DESC LIMIT 25",
          "refId": "A"
        }
      ],
      "title": "Latest Dead-Letter Records",
      "type": "table"
