          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT minute AS time, rejection_reason AS metric, sum(record_count) AS value\n                FROM agg_dlq_minute\n                WHERE $__timeFilter(minute)\n                GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Rejections per Minute by Reason",
      "type": "timeseries"
